EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_OR_PUBLISHABLE_KEY

# One-time: apply storage RLS for profile avatars to production (Settings → Database → database password)
# Then: npm run db:apply-avatar-rls && npm run verify:storage-avatar
# SUPABASE_DB_PASSWORD=

# Vercel only: service role for /api/* routes (optional if clients use direct Supabase inserts).
# Used by avatar-upload, scam-report, pilot-delete-scam-alert, etc. when those routes run on the server.
# Set in the Vercel project (Settings → Environment Variables), not the client bundle.
# SUPABASE_SERVICE_ROLE_KEY=(from Supabase → Settings → API)

# Optional: override the origin used for /api/avatar-upload (default on web = same host; on native = bandits-two.vercel.app)
# EXPO_PUBLIC_AVATAR_API_BASE=

# Supabase Auth user UUID for Pilot Desk / operator routing (Authentication → Users → User UID)
EXPO_PUBLIC_OPERATOR_USER_ID=

# Comma-separated accounts allowed to open Admin, Hotelier, and Pilot Desk (must also match operator UID for desk)
EXPO_PUBLIC_APP_ADMIN_EMAILS=

# Local only: `npm run verify:pilot-flows` (do not commit real values; use .env.local)
# E2E_ADMIN_EMAIL=
# E2E_ADMIN_PASSWORD=

# Pilot: simulated inbox lines + timed Local Friend sample replies (client-side; does not write fake rows to Supabase)
EXPO_PUBLIC_DEMO_MODE=false

# Pilot hotel guest PWA URL (QR, Hotelier copy). Must match the Vercel project where you run `npm run build` for web.
# Example second project: https://bandits-two.vercel.app/hotel/play-theatrou
EXPO_PUBLIC_PLAY_GUEST_ENTRY_URL=https://bandits-two.vercel.app/hotel/play-theatrou
