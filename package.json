{
  "name": "bandits",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "postinstall": "node scripts/patch-expo-win-externals.cjs",
    "start": "node scripts/start-expo-lan.cjs",
    "reset-project": "node ./scripts/reset-project.js",
    "upload-event-images": "node ./scripts/upload-event-images.js",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "eas:sync-env": "node scripts/sync-eas-env.cjs",
    "deploy": "npm run build && npx netlify-cli deploy  --dir=dist",
    "deploy-prod": "npm run build && npx netlify-cli deploy  --prod --dir=dist",
    "build": "npx expo export --platform web && node scripts/prepare-pwa.js && npx workbox-cli generateSW workbox-config.js && node scripts/inject-sw.js"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-picker/picker": "2.11.1",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/elements": "^1.3.31",
    "@react-navigation/native": "^7.1.8",
    "@supabase/supabase-js": "^2.50.3",
    "@types/leaflet": "^1.9.20",
    "axios": "^1.10.0",
    "dotenv": "^17.2.1",
    "expo": "^54.0.0",
    "expo-auth-session": "~7.0.10",
    "expo-blur": "~15.0.8",
    "expo-build-properties": "~1.0.10",
    "expo-constants": "~18.0.13",
    "expo-crypto": "~15.0.8",
    "expo-dev-client": "~6.0.20",
    "expo-file-system": "~19.0.21",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-image-picker": "~17.0.10",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.11",
    "expo-location": "~19.0.8",
    "expo-router": "~6.0.23",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-symbols": "~1.0.8",
    "expo-system-ui": "~6.0.9",
    "expo-updates": "~29.0.16",
    "expo-video": "~3.0.16",
    "expo-web-browser": "~15.0.10",
    "leaflet": "^1.9.4",
    "lodash": "^4.17.21",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-leaflet": "^4.2.1",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-svg-transformer": "^1.5.1",
    "react-native-web": "^0.21.0",
    "react-native-webview": "13.15.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@react-native-community/cli": "^20.0.1",
    "@types/react": "~19.1.10",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~10.0.0",
    "typescript": "~5.9.2",
    "workbox-cli": "^7.3.0"
  },
  "private": true
}
